# ============================================
# Archivos técnicos de Python (los genera automáticamente)
# ============================================
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/

# Jupyter (checkpoints automáticos que no sirven para nada)
.ipynb_checkpoints
*.ipynb_checkpoints

# Entornos virtuales (cada uno tiene el suyo, no hay que compartirlos)
venv/
env/
ENV/

# Configuración de editores (cada uno usa el suyo)
.vscode/
.idea/
*.swp
*.swo

# Archivos basura del sistema operativo
.DS_Store      # macOS
Thumbs.db      # Windows

# ============================================
# DATOS PERSONALES - NUNCA SUBIR ESTO
# ============================================
# Todas las imágenes y vídeos (son las fotos del usuario)
*.jpg
*.jpeg
*.png
*.heic
*.heif
*.mov
*.mp4
*.avi
*.gif
*.webp

# ============================================
# RESULTADOS DEL PIPELINE - PESAN DEMASIADO
# ============================================
# Los embeddings y modelos generados (se pueden regenerar ejecutando el notebook)
embeddings/
clusters/
outputs/
chroma_db/
analysis_logs/
session_state/
*.pkl          # Archivos pickle con embeddings
*.npy          # Arrays de NumPy
*.h5           # Modelos guardados
*.pth          # Modelos de PyTorch
*.onnx         # Modelos optimizados

# Carpetas típicas donde la gente guarda sus fotos
fotos/
photos/
imagenes/
Imagenes/
drive/         # Si monta Google Drive
MyDrive/
